# ─── 공공데이터포털 (전국장사시설) ──────────────
# 인증키: https://www.data.go.kr
SERVICE_KEY=
# 전국장사시설 조회 API 엔드포인트
# 예: http://apis.data.go.kr/XXXXXXX/XxxxService/callData04_1Api
API_URL=

# ─── 서버 ──────────────────────────────────
PORT=8000

# ─── Firebase (Firestore - 부고장 데이터) ────
# Firebase Console > 프로젝트 설정 > 일반 > 내 앱 (웹앱)
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_DATABASE_URL=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# ─── Supabase (Storage - 영정사진) ──────────
# Supabase Dashboard > Project Settings > API
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_BUCKET=photo

# ─── Kakao (지도 + 공유하기) ─────────────────
# Kakao Developers > 내 애플리케이션 > 앱 키 > JavaScript 키
KAKAO_KEY=
